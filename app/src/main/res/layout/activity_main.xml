<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center_horizontal"
    android:padding="24dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="GarD Command Center"
        android:textSize="28sp"
        android:layout_marginBottom="16dp"/>

    <TextView
        android:id="@+id/tvStatus"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Status: Idle"
        android:textSize="18sp"
        android:layout_marginBottom="16dp"/>

    <!-- CONNECTION SCREEN -->
    <LinearLayout
        android:id="@+id/layoutConnect"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center">

        <EditText
            android:id="@+id/etPairingCode"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Pairing Code (if new pump)"
            android:textSize="18sp"
            android:layout_marginBottom="16dp"
            android:gravity="center"/>

        <Button
            android:id="@+id/btnConnect"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:text="Connect to Pump"
            android:textSize="18sp"
            android:layout_marginBottom="16dp"/>
    </LinearLayout>

    <!-- MAIN DASHBOARD -->
    <LinearLayout
        android:id="@+id/layoutMain"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:visibility="gone"
        android:gravity="center">

        <TextView
            android:id="@+id/tvCGM"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="CGM: NA"
            android:textSize="20sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:id="@+id/tvBattery"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Battery: --%"
            android:textSize="20sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:id="@+id/tvIOB"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="IOB: -- U"
            android:textSize="20sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:id="@+id/tvInsulin"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Insulin Remaining: -- U"
            android:textSize="20sp"
            android:textStyle="bold"
            android:layout_marginBottom="16dp"/>
            
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginBottom="16dp">
            
            <EditText
                android:id="@+id/etBolusUnits"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:hint="Units"
                android:inputType="numberDecimal"
                android:textSize="18sp"/>
                
            <Button
                android:id="@+id/btnBolus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="BOLUS"
                android:textColor="#FFFFFF"
                app:backgroundTint="#D32F2F" />
        </LinearLayout>
    </LinearLayout>

    <Button
        android:id="@+id/btnCopyLogs"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="COPY LOGS"
        android:layout_marginBottom="16dp"/>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="#111111"
        android:visibility="gone"
        android:padding="8dp">

        <TextView
            android:id="@+id/tvLog"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#0F0"
            android:fontFamily="monospace"
            android:textSize="12sp"
            android:textIsSelectable="true"
            android:text="Logs will appear here..."/>
    </ScrollView>

</LinearLayout>
